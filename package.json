{
  "name": "the-chronicle-v2",
  "version": "0.1.2",
  "description": "The Chronicle — a personal dashboard, packaged as a one-click desktop app with an in-app Settings UI and guided account connections.",
  "author": "David <davidcjw@gmail.com>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "server": "node src/supervisor.js",
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "express": "^4.19.2",
    "googleapis": "^140.0.1",
    "node-fetch": "^3.3.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.davidcjw.thechronicle",
    "productName": "The Chronicle",
    "files": ["electron/**", "src/**", "plugins/**", "public/**", "dashboard.config.js"],
    "asarUnpack": ["plugins/apple-reminders/**"],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "identity": null,
      "icon": "build/icon.icns"
    }
  }
}
